NO_PROXY=10.51.0.79,172.16.2.157,172.16.1.144,10.8.98.9,localhost,127.0.0.1,47.97.202.126

HEZOR2_API_BASE_URL=http://your_hezor2_api_base_url_here
HEZOR2_API_KEY=your_hezor2_api_key_here
HEZOR2_HEADER_PK_FILEPATH=security/private_key.pem
HEZOR2_HEADER_PK_PASSWORD=file_password
HEZOR2_APP_NAME=pestiot_v5

# OAuth 2.0 client（examples/oauth-auth-code.ts、examples/oauth-device-flow.ts）
# Casdoor Application.client_id（必填）
OAUTH_CLIENT_ID=your_oauth_client_id_here
# Auth Code 模式回调 URL，需在 application.redirect_uris 白名单内
OAUTH_REDIRECT_URI=http://localhost:3003/callback
# 空格分隔 scope，按需调整
OAUTH_SCOPE=base:user-info base:llm-invoke
# Device Flow 用：设备唯一指纹（与 silicon_runtime.device_id 同来源）
OAUTH_DEVICE_ID=demo-device-001



